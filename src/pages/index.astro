---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- ═══════════ NAVBAR ═══════════ -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-black/40 backdrop-blur-sm">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="#" class="flex items-center gap-2">
        <svg class="w-6 h-6 text-[var(--color-blue)] scissors-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M14.121 14.121A3 3 0 1 0 9.88 9.88M7.05 7.05l9.9 9.9M16.95 7.05l-9.9 9.9"/></svg>
        <span class="font-display text-xl font-bold text-white nav-logo tracking-wide">ÁNGEL HUERTA</span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#servicios" class="text-sm text-white/80 hover:text-white transition-colors nav-link">Servicios</a>
        <a href="#sobre-mi" class="text-sm text-white/80 hover:text-white transition-colors nav-link">Sobre mí</a>
        <a href="#galeria" class="text-sm text-white/80 hover:text-white transition-colors nav-link">Galería</a>
        <a href="#testimonios" class="text-sm text-white/80 hover:text-white transition-colors nav-link">Opiniones</a>
        <a href="#contacto" class="text-sm text-white/80 hover:text-white transition-colors nav-link">Contacto</a>
        <a href="#reservar" class="nav-cta bg-[var(--color-blue)] text-white px-6 py-2.5 rounded-full font-semibold text-sm shadow-lg shadow-[var(--color-blue)]/20 flex items-center gap-1.5">
          Reservar Cita <span class="text-xs">→</span>
        </a>
      </div>
      <button id="mobile-toggle" class="md:hidden text-white p-2" aria-label="Menú">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
    <div id="mobile-menu" class="md:hidden hidden bg-white/95 backdrop-blur-xl border-t border-[var(--color-border)]">
      <div class="px-6 py-6 flex flex-col gap-4">
        <a href="#servicios" class="text-[var(--color-text)] hover:text-[var(--color-blue)] transition-colors py-2 mobile-link">Servicios</a>
        <a href="#sobre-mi" class="text-[var(--color-text)] hover:text-[var(--color-blue)] transition-colors py-2 mobile-link">Sobre mí</a>
        <a href="#galeria" class="text-[var(--color-text)] hover:text-[var(--color-blue)] transition-colors py-2 mobile-link">Galería</a>
        <a href="#testimonios" class="text-[var(--color-text)] hover:text-[var(--color-blue)] transition-colors py-2 mobile-link">Opiniones</a>
        <a href="#contacto" class="text-[var(--color-text)] hover:text-[var(--color-blue)] transition-colors py-2 mobile-link">Contacto</a>
        <a href="#reservar" class="bg-[var(--color-blue)] text-white px-6 py-3 rounded-full font-semibold text-sm text-center mt-2 mobile-link">Reservar Cita</a>
      </div>
    </div>
  </nav>


  <!-- ═══════════ HERO ═══════════ -->
  <section class="relative min-h-screen flex items-center">
    <img src="/img/hero-bg.jpg" alt="Barbería Ángel Huerta" class="absolute inset-0 w-full h-full object-cover hero-parallax" loading="eager" />
    <div class="hero-overlay absolute inset-0"></div>

    <!-- Deco circles -->
    <div class="deco-circle w-[500px] h-[500px] -top-40 -right-40" style="position:absolute;"></div>
    <div class="deco-circle w-[300px] h-[300px] bottom-20 left-10" style="position:absolute;"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 pt-28 pb-20 w-full">
      <div class="max-w-2xl">
        <!-- Badge with animated glow border -->
        <div class="hero-fade hero-fade-d1 badge-glow inline-flex items-center gap-2 px-5 py-2 mb-8 rounded-full">
          <svg class="w-4 h-4 text-[var(--color-blue)]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          <span class="text-sm text-white/90 font-medium">Puerto de Sagunto, Valencia</span>
        </div>

        <h1 class="hero-fade hero-fade-d2 font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl text-white font-bold leading-[1.05] mb-6">
          Tu barbero<br/>de <em class="italic text-[var(--color-blue)]">confianza</em>
        </h1>

        <p class="hero-fade hero-fade-d3 text-white/70 text-lg md:text-xl max-w-lg mb-10 leading-relaxed">
          Más de 40 años de experiencia haciendo que cada cliente salga sintiéndose su mejor versión.
        </p>

        <div class="hero-fade hero-fade-d4 flex flex-col sm:flex-row gap-4 items-start">
          <a href="#reservar" class="btn-shimmer bg-[var(--color-blue)] text-white px-8 py-4 rounded-full font-semibold text-sm flex items-center gap-2">
            Reservar Cita <span>→</span>
          </a>
          <a href="#servicios" class="btn-ghost border border-white/30 text-white px-8 py-4 rounded-full font-semibold text-sm">
            Ver Servicios
          </a>
        </div>

        <!-- Rating -->
        <div class="hero-fade hero-fade-d5 mt-8 flex items-center gap-3">
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <span class="text-white/60 text-sm">+200 reseñas en Google</span>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════ BARRA DE CONFIANZA ═══════════ -->
  <section class="bg-white border-b border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto px-6 py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0 md:divide-x divide-[var(--color-border)]">
        {[
          { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', label: '40+ años', sub: 'de experiencia' },
          { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z', label: 'Miles', sub: 'de clientes' },
          { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', label: '5 ★', sub: 'en Google' },
          { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', label: 'Puerto de Sagunto', sub: 'Valencia' },
        ].map(({ icon, label, sub }) => (
          <div class="flex items-center gap-3 md:justify-center md:px-4">
            <svg class="w-5 h-5 text-[var(--color-blue)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={icon}/></svg>
            <div>
              <p class="text-sm font-bold text-[var(--color-black)]">{label}</p>
              <p class="text-xs text-[var(--color-text)]">{sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════ SERVICIOS (01) ═══════════ -->
  <section id="servicios" class="relative py-20 md:py-28 px-6 bg-[var(--color-light)] overflow-hidden">
    <!-- Section number decorativo -->
    <span class="section-number top-4 right-6">01</span>
    <!-- Deco circles -->
    <div class="deco-circle w-[200px] h-[200px] -top-20 -left-20"></div>
    <div class="deco-circle w-[350px] h-[350px] -bottom-40 -right-32"></div>

    <div class="max-w-4xl mx-auto relative z-10">
      <div class="text-center mb-16 reveal">
        <span class="section-tag text-[var(--color-blue)] text-xs font-semibold uppercase tracking-widest">Servicios</span>
        <h2 class="heading-xl text-3xl md:text-5xl mb-4">Nuestros <em>servicios</em></h2>
        <p class="text-[var(--color-text)] text-lg max-w-md mx-auto">Todo lo que necesitas en un solo sitio, con la calidad de siempre</p>
      </div>

      <div class="reveal-stagger space-y-0">
        {[
          { title: 'Corte Clásico', price: '15€', desc: 'Corte tradicional a tijera con acabado perfecto' },
          { title: 'Degradado', price: '14€', desc: 'Skin fade, mid fade o high fade adaptado a tu estilo' },
          { title: 'Afeitado Clásico', price: '10€', desc: 'Navaja con toalla caliente. Experiencia de barbería clásica' },
          { title: 'Arreglo de Barba', price: '8€', desc: 'Perfilado, recorte y cuidado de barba' },
          { title: 'Corte + Barba', price: '18€', desc: 'El servicio completo en una sola sesión' },
          { title: 'Tratamiento Capilar', price: 'Consultar', desc: 'Tratamientos personalizados para la salud de tu cabello' },
        ].map(({ title, price, desc }) => (
          <div class="service-row py-5 px-2 flex items-baseline rounded-lg">
            <div class="shrink-0">
              <h3 class="text-lg font-bold text-[var(--color-black)]">{title}</h3>
              <p class="text-sm text-[var(--color-text)] mt-0.5">{desc}</p>
            </div>
            <span class="service-dot-line"></span>
            <span class="text-xl font-bold text-[var(--color-blue)] shrink-0 font-display">{price}</span>
          </div>
        ))}
      </div>

      <div class="text-center mt-14 reveal">
        <a href="#reservar" class="btn-shimmer inline-flex items-center gap-2 bg-[var(--color-blue)] text-white px-8 py-4 rounded-full font-semibold text-sm">
          Reservar Cita <span>→</span>
        </a>
      </div>
    </div>
  </section>


  <!-- Wave divider: light → white -->
  <div class="wave-divider">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,60 C360,0 720,40 1080,10 C1260,-5 1380,20 1440,30 L1440,60 Z" fill="#ffffff"/>
    </svg>
  </div>


  <!-- ═══════════ ANTES / DESPUÉS (02) ═══════════ -->
  <section class="relative py-20 md:py-28 px-6 bg-white overflow-hidden">
    <span class="section-number top-4 left-6">02</span>
    <div class="deco-circle w-[250px] h-[250px] top-10 -right-24"></div>

    <div class="max-w-4xl mx-auto relative z-10">
      <div class="text-center mb-14 reveal">
        <span class="section-tag text-[var(--color-blue)] text-xs font-semibold uppercase tracking-widest">Resultados</span>
        <h2 class="heading-xl text-3xl md:text-5xl mb-4">El resultado habla <em>por sí solo</em></h2>
        <p class="text-[var(--color-text)] text-lg">Arrastra para comparar el antes y después</p>
      </div>

      <div class="ba-slider reveal" id="ba-slider" style="aspect-ratio: 4/3;">
        <!-- Before -->
        <img src="/img/before.jpg" alt="Antes" class="w-full h-full object-cover" />
        <!-- After -->
        <div class="ba-after" id="ba-after" style="clip-path: inset(0 50% 0 0);">
          <img src="/img/after.jpg" alt="Después" class="w-full h-full object-cover" />
        </div>
        <!-- Handle -->
        <div class="ba-handle" id="ba-handle" style="left: 50%;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3E76B6" stroke-width="2.5" stroke-linecap="round"><path d="M8 5l-5 7 5 7M16 5l5 7-5 7"/></svg>
        </div>
        <!-- Labels -->
        <span class="ba-label absolute top-4 left-4 text-white text-xs font-semibold px-3 py-1.5 rounded-full z-20">ANTES</span>
        <span class="ba-label absolute top-4 right-4 text-white text-xs font-semibold px-3 py-1.5 rounded-full z-20 !bg-[var(--color-blue)]">DESPUÉS</span>
      </div>

      <div class="text-center mt-14 reveal">
        <p class="text-[var(--color-black)] text-xl md:text-2xl font-display font-bold mb-6">¿Quieres estos resultados?</p>
        <a href="#reservar" class="btn-shimmer inline-flex items-center gap-2 bg-[var(--color-blue)] text-white px-8 py-4 rounded-full font-semibold text-sm">
          Reserva tu cita <span>→</span>
        </a>
      </div>
    </div>
  </section>


  <!-- Line separator -->
  <div class="line-separator max-w-6xl mx-auto"></div>


  <!-- ═══════════ SOBRE ÁNGEL (03) ═══════════ -->
  <section id="sobre-mi" class="relative py-20 md:py-28 px-6 bg-white overflow-hidden">
    <span class="section-number -top-2 right-6">03</span>
    <div class="deco-circle w-[400px] h-[400px] -bottom-48 -left-32"></div>

    <div class="max-w-6xl mx-auto relative z-10">
      <div class="grid md:grid-cols-12 gap-12 items-center">
        <!-- Foto con partial-border -->
        <div class="md:col-span-5 reveal-left">
          <div class="relative">
            <div class="partial-border-tl partial-border-br aspect-[3/4] rounded-2xl overflow-hidden shadow-xl">
              <img src="/img/barber-portrait.jpg" alt="Ángel Huerta, barbero profesional en Puerto de Sagunto" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="absolute -bottom-4 -right-4 bg-[var(--color-blue)] text-white px-5 py-3 rounded-xl shadow-lg">
              <p class="font-display text-2xl font-bold">40+</p>
              <p class="text-xs text-white/80">años de oficio</p>
            </div>
          </div>
        </div>

        <div class="md:col-span-7 reveal-right">
          <span class="section-tag text-[var(--color-blue)] text-xs font-semibold uppercase tracking-widest">Sobre mí</span>
          <h2 class="heading-xl text-3xl md:text-5xl mb-8">Ángel <em>Huerta</em></h2>

          <p class="text-[var(--color-text)] leading-relaxed mb-5 text-lg">
            Llevo más de 40 años detrás de la silla de barbero. Empecé siendo un chaval en Puerto de Sagunto y aquí sigo, haciendo lo que más me gusta: que cada cliente salga sintiéndose mejor.
          </p>
          <p class="text-[var(--color-text)] leading-relaxed mb-8">
            Fuera de la barbería, el culturismo me enseñó disciplina y constancia. Y cuando necesito desconectar, me subo a la moto y me pierdo por carretera. Pero siempre vuelvo a lo mío: las tijeras y la navaja.
          </p>

          <blockquote class="border-l-4 border-[var(--color-blue)] pl-6 mb-10 relative">
            <svg class="absolute -top-3 -left-1 w-8 h-8 text-[var(--color-blue)]/20" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z"/></svg>
            <p class="text-[var(--color-black)] text-lg italic leading-relaxed font-display">
              "No es solo un corte de pelo. Es hacer que te mires al espejo y te gustes."
            </p>
          </blockquote>

          <!-- Stats con stat-number -->
          <div class="grid grid-cols-3 gap-6">
            <div>
              <p class="stat-number text-3xl md:text-4xl text-[var(--color-blue)] counter" data-target="40">0</p>
              <p class="text-[var(--color-text)] text-sm mt-1">años de oficio</p>
            </div>
            <div>
              <p class="stat-number text-3xl md:text-4xl text-[var(--color-blue)]">Miles</p>
              <p class="text-[var(--color-text)] text-sm mt-1">de clientes</p>
            </div>
            <div>
              <p class="stat-number text-3xl md:text-4xl text-[var(--color-blue)] counter" data-target="1">0</p>
              <p class="text-[var(--color-text)] text-sm mt-1">pasión</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Wave divider: white → nardo -->
  <div class="wave-divider">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 C480,60 960,0 1440,40 L1440,60 L0,60 Z" fill="var(--color-nardo)"/>
    </svg>
  </div>


  <!-- ═══════════ TESTIMONIOS (04) ═══════════ -->
  <section id="testimonios" class="relative py-20 md:py-28 px-6 bg-[var(--color-nardo)] overflow-hidden">
    <span class="section-number top-4 left-6">04</span>
    <div class="deco-circle w-[300px] h-[300px] top-20 -right-32"></div>

    <div class="max-w-6xl mx-auto relative z-10">
      <div class="text-center mb-14 reveal">
        <span class="section-tag text-[var(--color-blue)] text-xs font-semibold uppercase tracking-widest mx-auto">Opiniones</span>
        <h2 class="heading-xl text-3xl md:text-5xl mb-4">Lo que dicen nuestros <em>clientes</em></h2>
      </div>

      <!-- 1 featured + 2 small layout -->
      <div class="grid md:grid-cols-2 gap-6 reveal">
        <!-- Featured testimonial -->
        <div class="testimonial-featured bg-white rounded-2xl p-8 md:p-10 shadow-sm relative overflow-hidden dot-pattern">
          <span class="quote-mark top-4 left-6">"</span>
          <div class="relative z-10">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-[var(--color-text)] text-lg italic leading-relaxed mb-8 font-display">
              "Llevo yendo a Ángel más de 15 años. No cambio de barbero ni loco. Es un crack con las tijeras y siempre sabe lo que quiero antes de que se lo diga."
            </p>
            <div class="flex items-center gap-4">
              <img src="/img/avatar-1.jpg" alt="Carlos M." class="w-14 h-14 rounded-full object-cover" loading="lazy" />
              <div>
                <p class="font-bold text-[var(--color-black)] text-lg">Carlos M.</p>
                <p class="text-sm text-[var(--color-text)]">Cliente desde 2011</p>
              </div>
            </div>
          </div>
        </div>

        <!-- 2 small testimonials stacked -->
        <div class="flex flex-col gap-6">
          <div class="testimonial-small bg-white rounded-2xl p-7 shadow-sm">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-[var(--color-text)] italic leading-relaxed mb-5">"Mi padre ya iba con él. Ahora voy yo con mis hijos. Tres generaciones en la misma silla."</p>
            <div class="flex items-center gap-3">
              <img src="/img/avatar-2.jpg" alt="David R." class="w-10 h-10 rounded-full object-cover" loading="lazy" />
              <div>
                <p class="text-sm font-bold text-[var(--color-black)]">David R.</p>
                <p class="text-xs text-[var(--color-text)]">Cliente desde 2018</p>
              </div>
            </div>
          </div>

          <div class="testimonial-small bg-white rounded-2xl p-7 shadow-sm">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
