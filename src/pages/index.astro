---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- ████ NAVBAR ████ -->
<nav id="nav" class="nav-glass fixed inset-x-0 top-0 z-50 px-6 py-4">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <a href="#" class="text-lg font-bold tracking-[.25em] uppercase nav-white text-white">Ángel Huerta</a>
    <div class="hidden md:flex items-center gap-10">
      <a href="#servicios" class="nav-white text-white/80 text-[13px] tracking-widest uppercase hover:text-white transition">Servicios</a>
      <a href="#historia" class="nav-white text-white/80 text-[13px] tracking-widest uppercase hover:text-white transition">Historia</a>
      <a href="#galeria" class="nav-white text-white/80 text-[13px] tracking-widest uppercase hover:text-white transition">Galería</a>
      <a href="#reservar" class="bg-[var(--blue)] text-white text-[13px] tracking-wider uppercase font-semibold px-6 py-2.5 rounded-full hover:brightness-110 transition">Reservar</a>
    </div>
    <button id="burger" class="md:hidden nav-white text-white" aria-label="Menú">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>
  <div id="mob-menu" class="hidden md:hidden bg-white/95 backdrop-blur-xl mt-2 rounded-2xl shadow-xl p-6 space-y-4">
    <a href="#servicios" class="block text-sm text-[var(--text)] mob-link">Servicios</a>
    <a href="#historia" class="block text-sm text-[var(--text)] mob-link">Historia</a>
    <a href="#galeria" class="block text-sm text-[var(--text)] mob-link">Galería</a>
    <a href="#reservar" class="block bg-[var(--blue)] text-white text-center text-sm font-semibold py-3 rounded-full mob-link">Reservar cita</a>
  </div>
</nav>


<!-- ████ HERO — FULLSCREEN CINEMATIC ████ -->
<section class="snap-section relative overflow-hidden bg-black">
  <img src="/img/hero-bg.jpg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-40 scale-110" id="hero-img" />
  <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>

  <div class="relative z-10 w-full px-6">
    <div class="max-w-7xl mx-auto">
      <!-- Big display text -->
      <div class="overflow-hidden mb-4">
        <h1 class="text-reveal text-reveal-d1 font-[Playfair_Display] text-white text-[clamp(3rem,8vw,7rem)] font-bold leading-[0.95] tracking-tight">
          Ángel Huerta
        </h1>
      </div>
      <div class="overflow-hidden mb-8">
        <p class="text-reveal text-reveal-d2 text-white/50 text-[clamp(1rem,2.5vw,1.5rem)] font-light tracking-[.15em] uppercase">
          Barbería · Puerto de Sagunto
        </p>
      </div>
      <div class="overflow-hidden mb-12">
        <p class="text-reveal text-reveal-d3 text-white/40 text-lg max-w-md leading-relaxed">
          Más de 40 años de oficio. Una silla. Miles de historias.
        </p>
      </div>

      <div class="flex gap-4 items-center" style="animation: textReveal 1s cubic-bezier(0.77,0,0.175,1) 1.1s both; clip-path: inset(0 100% 0 0);">
        <a href="#reservar" class="bg-[var(--blue)] text-white px-8 py-4 text-sm font-semibold tracking-wider uppercase rounded-full hover:brightness-110 transition">
          Pedir cita
        </a>
        <a href="#historia" class="text-white/50 text-sm tracking-wider uppercase hover:text-white transition flex items-center gap-2">
          Descubrir <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent z-10"></div>
</section>


<!-- ████ MARQUEE — TRUST STRIP ████ -->
<section class="py-6 bg-white overflow-hidden border-b border-gray-100">
  <div class="marquee-track">
    {[...Array(2)].map(() => (
      <div class="flex items-center gap-16 px-8">
        <span class="text-[var(--black)] text-sm font-semibold whitespace-nowrap">★★★★★ +200 Reseñas Google</span>
        <span class="text-gray-300">·</span>
        <span class="text-[var(--text)] text-sm whitespace-nowrap">40+ años de experiencia</span>
        <span class="text-gray-300">·</span>
        <span class="text-[var(--text)] text-sm whitespace-nowrap">Puerto de Sagunto, Valencia</span>
        <span class="text-gray-300">·</span>
        <span class="text-[var(--text)] text-sm whitespace-nowrap">Miles de clientes satisfechos</span>
        <span class="text-gray-300">·</span>
        <span class="text-[var(--text)] text-sm whitespace-nowrap">Reserva online con Booksy</span>
        <span class="text-gray-300">·</span>
      </div>
    ))}
  </div>
</section>


<!-- ████ SERVICIOS — LISTA HORIZONTAL ELEGANTE ████ -->
<section id="servicios" class="py-28 md:py-36 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-[1fr,2fr] gap-16 items-start">
      <!-- Left col: heading sticky -->
      <div class="md:sticky md:top-32 fade-up">
        <p class="text-[var(--blue)] text-xs font-bold tracking-[.3em] uppercase mb-4">Servicios</p>
        <h2 class="font-[Playfair_Display] text-4xl md:text-5xl text-[var(--black)] font-bold leading-tight mb-6">
          Lo que<br/><em class="italic text-[var(--blue)]">hacemos</em>
        </h2>
        <p class="text-[var(--text)] leading-relaxed">Cada servicio con la atención y el detalle que solo 40 años de experiencia pueden dar.</p>
      </div>

      <!-- Right col: services -->
      <div class="fade-up fade-up-d2">
        {[
          { num: '01', title: 'Corte Clásico', price: '15€', desc: 'Tijera, máquina o ambas. El corte de siempre, perfeccionado.' },
          { num: '02', title: 'Degradado', price: '14€', desc: 'Skin fade, mid fade o lo que pidas. Limpio y preciso.' },
          { num: '03', title: 'Afeitado a Navaja', price: '10€', desc: 'Toalla caliente, navaja y aftershave. Barbería clásica de verdad.' },
          { num: '04', title: 'Arreglo de Barba', price: '8€', desc: 'Perfilado, recorte y forma. Tu barba en su mejor momento.' },
          { num: '05', title: 'Corte + Barba', price: '18€', desc: 'El combo completo. Entra, relájate, sal nuevo.' },
          { num: '06', title: 'Tratamiento Capilar', price: 'Consultar', desc: 'Hidratación, keratina y cuidado personalizado.' },
        ].map(({ num, title, price, desc }) => (
          <div class="group border-b border-gray-100 py-6 md:py-8 hover:bg-[var(--nardo)]/10 transition-colors duration-300 px-4 -mx-4 rounded-xl">
            <div class="flex items-baseline gap-4 mb-2">
              <span class="text-[var(--blue)]/30 text-xs font-mono">{num}</span>
              <h3 class="text-lg md:text-xl font-bold text-[var(--black)] group-hover:text-[var(--blue)] transition-colors flex-1">{title}</h3>
              <span class="text-[var(--blue)] font-bold text-lg font-[Playfair_Display]">{price}</span>
            </div>
            <p class="text-[var(--text)] text-sm pl-10">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>


<!-- ████ ANTES / DESPUÉS — FULLWIDTH ████ -->
<section class="py-28 md:py-36 bg-[var(--nardo)]/30">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-16 fade-up">
      <p class="text-[var(--blue)] text-xs font-bold tracking-[.3em] uppercase mb-4">Resultados</p>
      <h2 class="font-[Playfair_Display] text-4xl md:text-5xl text-[var(--black)] font-bold">
        Hablan los <em class="italic text-[var(--blue)]">hechos</em>
      </h2>
    </div>

    <div class="ba-wrap rounded-3xl aspect-[16/10] md:aspect-[16/9] fade-up" id="ba">
      <img src="/img/before.jpg" alt="Antes" class="w-full h-full object-cover rounded-3xl" />
      <div class="ba-over rounded-3xl" id="ba-over" style="clip-path: inset(0 50% 0 0);">
        <img src="/img/after.jpg" alt="Después" class="w-full h-full object-cover" />
      </div>
      <div class="ba-line" id="ba-line" style="left:50%;">
        <div class="ba-knob">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2.5" stroke-linecap="round"><path d="M8 5l-5 7 5 7M16 5l5 7-5 7"/></svg>
        </div>
      </div>
      <span class="absolute top-5 left-5 bg-black/50 backdrop-blur text-white text-[11px] font-bold tracking-widest uppercase px-4 py-1.5 rounded-full z-20">Antes</span>
      <span class="absolute top-5 right-5 bg-[var(--blue)] text-white text-[11px] font-bold tracking-widest uppercase px-4 py-1.5 rounded-full z-20">Después</span>
    </div>

    <div class="text-center mt-16 fade-up">
      <p class="text-2xl md:text-3xl font-[Playfair_Display] text-[var(--black)] font-bold mb-6">¿Quieres este resultado?</p>
      <a href="#reservar" class="inline-block bg-[var(--blue)] text-white px-10 py-4 text-sm font-semibold tracking-wider uppercase rounded-full hover:brightness-110 transition">
        Pedir cita →
      </a>
    </div>
  </div>
</section>


<!-- ████ HISTORIA — SPLIT LAYOUT EDITORIAL ████ -->
<section id="historia" class="snap-section bg-white overflow-hidden">
  <div class="w-full grid md:grid-cols-2 min-h-screen">
    <!-- Left: foto fullheight -->
    <div class="relative img-zoom h-[50vh] md:h-auto overflow-hidden">
      <img src="/img/barber-portrait.jpg" alt="Ángel Huerta" class="w-full h-full object-cover" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent md:bg-gradient-to-r md:from-transparent md:to-black/10"></div>
    </div>

    <!-- Right: texto editorial -->
    <div class="flex items-center px-8 md:px-16 lg:px-24 py-16 md:py-0">
      <div class="max-w-lg fade-up">
        <p class="text-[var(--blue)] text-xs font-bold tracking-[.3em] uppercase mb-6">Sobre Ángel</p>

        <div class="big-num text-[var(--nardo)] mb-2 select-none" aria-hidden="true">40</div>
        <p class="text-[var(--text)] text-xs tracking-[.2em] uppercase mb-10">Años de oficio</p>

        <h2 class="font-[Playfair_Display] text-3xl md:text-4xl text-[var(--black)] font-bold leading-snug mb-8">
          Un chaval de Puerto de Sagunto que encontró su <em class="italic text-[var(--blue)]">pasión</em>
        </h2>

        <p class="text-[var(--text)] leading-relaxed mb-5 text-[15px]">
          Empecé con 17 años. Desde entonces, la silla de barbero ha sido mi sitio. He visto cambiar las modas, las herramientas y las generaciones — pero lo importante sigue igual: que cada persona que se sienta en mi silla salga sintiéndose bien.
        </p>
        <p class="text-[var(--text)] leading-relaxed mb-10 text-[15px]">
          Fuera de aquí, el culturismo me enseñó disciplina. La moto me da libertad. Pero siempre vuelvo a lo mismo: las tijeras, la navaja y una buena conversación.
        </p>

        <blockquote class="border-l-[3px] border-[var(--blue)] pl-6">
          <p class="font-[Playfair_Display] text-[var(--black)] text-xl italic leading-relaxed">
            "No es solo un corte. Es hacer que te mires al espejo y te gustes."
          </p>
        </blockquote>
      </div>
    </div>
  </div>
</section>


<!-- ████ GALERÍA — HORIZONTAL SCROLL ████ -->
<section id="galeria" class="py-28 md:py-36 bg-[var(--black)]">
  <div class="max-w-7xl mx-auto mb-12 px-6 flex items-end justify-between">
    <div class="fade-up">
      <p class="text-[var(--blue)] text-xs font-bold tracking-[.3em] uppercase mb-4">Portfolio</p>
      <h2 class="font-[Playfair_Display] text-4xl md:text-5xl text-white font-bold">
        Nuestro <em class="italic text-[var(--blue)]">trabajo</em>
      </h2>
    </div>
    <p class="text-white/30 text-sm hidden md:block fade-up">Desliza →</p>
  </div>

  <div class="h-scroll fade-up">
    {[
      { src: '/img/gallery-1.jpg', w: 'w-[300px] md:w-[400px]', h: 'h-[400px] md:h-[500px]' },
      { src: '/img/gallery-2.jpg', w: 'w-[250px] md:w-[350px]', h: 'h-[350px] md:h-[450px]' },
      { src: '/img/gallery-3.jpg', w: 'w-[300px] md:w-[400px]', h: 'h-[400px] md:h-[500px]' },
      { src: '/img/gallery-4.jpg', w: 'w-[220px] md:w-[300px]', h: 'h-[350px] md:h-[450px]' },
      { src: '/img/gallery-5.jpg', w: 'w-[280px] md:w-[380px]', h: 'h-[400px] md:h-[500px]' },
      { src: '/img/gallery-6.jpg', w: 'w-[250px] md:w-[350px]', h: 'h-[350px] md:h-[450px]' },
    ].map(({ src, w, h }) => (
      <div class={`${w} ${h} rounded-2xl overflow-hidden relative group`}>
        <img src={src} alt="Trabajo" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-500"></div>
      </div>
    ))}
  </div>
</section>


<!-- ████ TESTIMONIOS — EDITORIAL ████ -->
<section class="py-28 md:py-36 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20 fade-up">
      <p class="text-[var(--blue)] text-xs font-bold tracking-[.3em] uppercase mb-4">Opiniones</p>
      <h2 class="font-[Playfair_Display] text-4xl md:text-5xl text-[var(--black)] font-bold">
        Clientes <em class="italic text-[var(--blue)]">reales</em>
      </h2>
    </div>

    <!-- Feature quote -->
    <div class="max-w-3xl mx-auto text-center mb-20 fade-up relative">
      <span class="font-[Playfair_Display] text-[8rem] md:text-[12rem] text-[var(--nardo)] leading-none absolute -top-16 left-1/2 -translate-x-1/2 select-none pointer-events-none" aria-hidden="true">"</span>
      <div class="relative z-10">
        <p class="font-[Playfair_Display] text-2xl md:text-3xl text-[var(--black)] italic leading-relaxed mb-8">
          Llevo yendo a Ángel más de 15 años. No cambio de barbero ni loco. Es un crack con las tijeras y siempre sabe lo que quiero antes de que se lo diga.
        </p>
        <div class="flex items-center justify-center gap-3">
          <img src="/img/avatar-1.jpg" alt="" class="w-12 h-12 rounded-full object-cover" loading="lazy" />
          <div class="text-left">
            <p class="text-sm font-bold text-[var(--black)]">Carlos M.</p>
            <p class="text-xs text-[var(--text)]">Cliente desde 2011</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Two smaller -->
    <div class="grid md:grid-cols-2 gap-8 fade-up">
      {[
        { text: 'Mi padre ya iba con él. Ahora voy yo con mis hijos. Tres generaciones en la misma silla.', name: 'David R.', since: 'Cliente desde 2018', img: '/img/avatar-2.jpg' },
        { text: 'El mejor degradado de todo Puerto de Sagunto, sin discusión. Y encima buen tío.', name: 'Javier L.', since: 'Cliente desde 2020', img: '/img/avatar-3.jpg' },
      ].map(({ text, name, since, img }) => (
        <div class="bg-[var(--nardo)]/15 rounded-2xl p-8 md:p-10">
          <div class="flex gap-0.5 mb-5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-[var(--text)] italic leading-relaxed mb-6 text-[15px]">"{text}"</p>
          <div class="flex items-center gap-3">
            <img src={img} alt="" class="w-10 h-10 rounded-full object-cover" loading="lazy" />
            <div>
              <p class="text-sm font-bold text-[var(--black)]">{name}</p>
              <p class="text-xs text-[var(--text)]">{since}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ████ RESERVAS — DARK CTA SECTION ████ -->
<section id="reservar" class="snap-section bg-[var(--black)] text-white relative overflow-hidden">
  <div class="absolute inset-0 opacity-5">
    <div class="w-full h-full" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,0.05) 35px, rgba(255,255,255,0.05) 36px);"></div>
  </div>

  <div class="relative z-10 w-full px-6">
    <div class="max-w-4xl mx-auto text-center">
      <div class="fade-up">
        <p class="text-[var(--blue)] text-xs font-bold tracking-[.3em] uppercase mb-6">Reservas</p>
        <h2 class="font-[Playfair_Display] text-4xl md:text-6xl font-bold leading-tight mb-6">
          ¿Listo para tu<br/><em class="italic text-[var(--blue)]">nuevo look</em>?
        </h2>
        <p class="text-white/50 text-lg max-w-md mx-auto mb-12">Reserva online o llámanos. Sin esperas, sin complicaciones.</p>
      </div>

      <!-- Booksy -->
      <div id="booksy-widget" class="fade-up bg-white/5 border border-white/10 rounded-3xl p-10 md:p-16 mb-12 min-h-[350px] flex items-center justify-center">
        <div class="text-center">
          <svg class="w-12 h-12 text-[var(--blue)] mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
          <p class="text-white/60 font-medium">Widget de Booksy</p>
          <p class="text-white/30 text-sm mt-1">Pega el código embed aquí</p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center fade-up">
        <a href="https://wa.me/34XXXXXXXXX" target="_blank" class="bg-[#25D366] text-white px-8 py-4 rounded-full text-sm font-semibold tracking-wider uppercase flex items-center justify-center gap-2 hover:brightness-110 transition">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <a href="tel:+34XXXXXXXXX" class="bg-white/10 border border-white/20 text-white px-8 py-4 rounded-full text-sm font-semibold tracking-wider uppercase flex items-center justify-center gap-2 hover:bg-white/20 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
          Llamar
        </a>
      </div>
    </div>
  </div>
</section>


<!-- ████ UBICACIÓN — MINIMAL ████ -->
<section class="py-28 md:py-36 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-start">
      <div class="fade-up">
        <p class="text-[var(--blue)] text-xs font-bold tracking-[.3em] uppercase mb-4">Ubicación</p>
        <h2 class="font-[Playfair_Display] text-3xl md:text-4xl text-[var(--black)] font-bold mb-10">
          Encuéntranos en<br/><em class="italic text-[var(--blue)]">Puerto de Sagunto</em>
        </h2>

