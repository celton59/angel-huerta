<script>
  // Nav scroll
  const nav = document.getElementById('nav')!;
  addEventListener('scroll', () => {
    const s = scrollY > 50;
    nav.classList.toggle('!bg-white/95', s);
    nav.classList.toggle('!backdrop-blur-md', s);
    nav.classList.toggle('!py-3', s);
    nav.classList.toggle('!shadow-md', s);
    nav.querySelectorAll('.nav-text').forEach(el => el.classList.toggle('!text-slate-900', s));
    nav.querySelectorAll('.nav-link').forEach(el => { el.classList.toggle('!text-slate-600', s); el.classList.toggle('text-slate-200', !s); });
  }, { passive: true });

  // Mobile menu
  document.getElementById('burger')!.onclick = () => document.getElementById('mob')!.classList.toggle('hidden');
  document.querySelectorAll('.ml').forEach(l => l.addEventListener('click', () => document.getElementById('mob')!.classList.add('hidden')));

  // Fade in
  const io = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('vis'); io.unobserve(e.target); }}), { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => io.observe(el));

  // BA slider
  const ba = document.getElementById('ba');
  const ov = document.getElementById('ba-over');
  const ln = document.getElementById('ba-line');
  if (ba && ov && ln) {
    let d = false;
    const m = (x: number) => { const r = ba.getBoundingClientRect(); let p = Math.max(2, Math.min(98, ((x-r.left)/r.width)*100)); ov.style.clipPath = `inset(0 ${100-p}% 0 0)`; ln.style.left = p+'%'; };
    ba.onmousedown = e => { d=true; m(e.clientX); };
    onmousemove = e => { if(d) m(e.clientX); };
    onmouseup = () => d=false;
    ba.addEventListener('touchstart', e => { d=true; m(e.touches[0].clientX); }, { passive: true });
    addEventListener('touchmove', e => { if(d) m(e.touches[0].clientX); });
    addEventListener('touchend', () => d=false);
  }
</script>
