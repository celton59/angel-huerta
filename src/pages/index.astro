---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- ████ NAV ████ -->
<nav id="nav" class="fixed w-full z-50 transition-all duration-500 bg-transparent py-6">
  <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
    <a href="#" class="flex items-center gap-2 group">
      <div class="bg-[var(--blue)] p-2 rounded-lg group-hover:rotate-180 transition-transform duration-500">
        <svg class="text-white w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M14.121 14.121A3 3 0 109.88 9.88m4.243 4.243L7.05 7.05m9.9 9.9L7.05 7.05m9.9 9.9L16.95 7.05l-9.9 9.9"/></svg>
      </div>
      <span class="text-xl font-black tracking-tighter nav-text text-white">ÁNGEL HUERTA</span>
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a href="#servicios" class="nav-link text-sm font-bold tracking-wide text-slate-200 hover:text-[var(--blue)] transition">SERVICIOS</a>
      <a href="#galeria" class="nav-link text-sm font-bold tracking-wide text-slate-200 hover:text-[var(--blue)] transition">GALERÍA</a>
      <a href="#contacto" class="nav-link text-sm font-bold tracking-wide text-slate-200 hover:text-[var(--blue)] transition">CONTACTO</a>
      <a href="#reservar" class="bg-[var(--blue)] text-white px-6 py-2.5 rounded-full font-bold text-xs tracking-wide hover:bg-[var(--blue-dark)] transition shadow-lg shadow-[var(--blue)]/20">RESERVAR EN BOOKSY</a>
    </div>
    <button id="burger" class="md:hidden nav-text text-white" aria-label="Menú">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>
  <div id="mob" class="hidden md:hidden absolute top-full left-0 w-full bg-white border-b border-slate-100 p-6 flex flex-col gap-4 shadow-2xl">
    <a href="#servicios" class="text-lg font-bold text-slate-800 ml">SERVICIOS</a>
    <a href="#galeria" class="text-lg font-bold text-slate-800 ml">GALERÍA</a>
    <a href="#contacto" class="text-lg font-bold text-slate-800 ml">CONTACTO</a>
    <a href="#reservar" class="bg-[var(--blue)] text-white text-center py-3 rounded-full font-bold ml">RESERVAR EN BOOKSY</a>
  </div>
</nav>


<!-- ████ HERO ████ -->
<section id="inicio" class="relative h-screen flex items-center justify-center overflow-hidden bg-slate-950">
  <div class="absolute inset-0">
    <img src="/img/hero-bg.jpg" alt="" class="hero-img w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/40 to-slate-950/60"></div>
  </div>

  <div class="relative z-10 max-w-5xl px-6 text-center">
    <div class="inline-flex items-center gap-2 bg-[var(--blue)]/10 border border-[var(--blue)]/20 text-[var(--blue)] px-4 py-1 rounded-full text-xs font-black mb-8 tracking-[0.2em]">
      ✦ MÁS DE 40 AÑOS DE OFICIO
    </div>

    <h1 class="text-6xl md:text-8xl lg:text-9xl font-black text-white mb-8 tracking-tighter leading-[0.9]">
      TU BARBERO <br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--blue)] to-sky-400 italic font-[Playfair_Display]">de Confianza.</span>
    </h1>

    <p class="text-lg md:text-xl text-slate-300 mb-12 max-w-2xl mx-auto font-light leading-relaxed">
      Cortes de precisión, afeitado clásico a navaja y el trato cercano de toda la vida. Puerto de Sagunto.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#reservar" class="bg-[var(--blue)] text-white h-16 px-10 rounded-full font-bold text-lg flex items-center justify-center gap-2 hover:bg-[var(--blue-dark)] transition shadow-lg shadow-[var(--blue)]/30 group">
        RESERVAR CITA <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="#servicios" class="h-16 px-10 rounded-full font-bold text-lg flex items-center justify-center border border-white/20 text-white hover:bg-white/10 transition">
        VER SERVICIOS
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-ind absolute bottom-10 left-1/2 text-white/30">
    <div class="w-6 h-10 border-2 border-white/20 rounded-full flex justify-center p-1">
      <div class="w-1 h-2 bg-[var(--blue)] rounded-full"></div>
    </div>
  </div>
</section>


<!-- ████ SERVICIOS ████ -->
<section id="servicios" class="py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-20">
      <div class="max-w-xl fade-in">
        <h2 class="text-5xl md:text-6xl font-black text-slate-900 mb-6 tracking-tighter">Servicios<br/>Exclusivos</h2>
        <p class="text-slate-500 text-lg border-l-4 border-[var(--blue)] pl-6">Más de 40 años perfeccionando cada corte, cada navajado, cada detalle.</p>
      </div>
      <div class="hidden md:block text-slate-300 font-black text-9xl select-none opacity-[0.07] translate-y-8">01</div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {[
        { icon: 'M14.121 14.121A3 3 0 109.88 9.88m4.243 4.243L7.05 7.05m9.9 9.9L7.05 7.05m9.9 9.9L16.95 7.05l-9.9 9.9', title: 'Corte Clásico', price: '15€', desc: 'Corte a tijera o máquina, adaptado a tu estilo. Incluye lavado y acabado.' },
        { icon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z', title: 'Ritual de Barba', price: '10€', desc: 'Afeitado tradicional a navaja con toalla caliente y aftershave premium.' },
        { icon: 'M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z', title: 'Experiencia Total', price: '18€', desc: 'Corte + barba + tratamiento. El pack completo. Entra, relájate, sal nuevo.' },
      ].map(({ icon, title, price, desc }) => (
        <div class="svc-card group p-12 rounded-[2.5rem] bg-slate-50 border border-slate-100 fade-in">
          <div class="svc-icon w-16 h-16 bg-[var(--blue)] text-white rounded-2xl flex items-center justify-center mb-10 shadow-lg shadow-[var(--blue)]/20">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={icon}/></svg>
          </div>
          <h3 class="text-2xl font-black text-slate-900 mb-4">{title}</h3>
          <p class="text-slate-500 mb-10 leading-relaxed font-medium">{desc}</p>
          <div class="flex items-center justify-between">
            <span class="text-4xl font-black text-slate-900">{price}</span>
            <a href="#reservar" class="svc-arrow bg-slate-900 text-white p-4 rounded-full inline-flex">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ████ GALERÍA ████ -->
<section id="galeria" class="py-32 bg-slate-950 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 text-center">
    <h2 class="text-5xl md:text-7xl font-black text-white mb-6 fade-in">
      NUESTRA <span class="text-[var(--blue)]">GALERÍA</span>
    </h2>
    <div class="w-24 h-1 bg-[var(--blue)] mx-auto rounded-full mb-16"></div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {[
        { src: '/img/gallery-1.jpg', tag: 'CLÁSICO' },
        { src: '/img/gallery-2.jpg', tag: 'DEGRADADO' },
        { src: '/img/gallery-3.jpg', tag: 'BARBA' },
        { src: '/img/gallery-4.jpg', tag: 'ESTILO' },
      ].map(({ src, tag }) => (
        <div class="gal-card group relative h-[450px] rounded-3xl overflow-hidden cursor-pointer fade-in">
          <img src={src} alt="Trabajo" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent p-8 flex flex-col justify-end text-left">
            <div class="gal-info">
              <span class="text-[var(--blue)] font-black text-xs tracking-widest mb-2 block">{tag}</span>
              <p class="text-white font-bold text-xl">Estilo Personalizado</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ████ ANTES / DESPUÉS ████ -->
<section class="py-32 bg-slate-50">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16">
      <div class="fade-in">
        <h2 class="text-5xl md:text-6xl font-black text-slate-900 tracking-tighter">Resultados <span class="text-[var(--blue)]">Reales</span></h2>
      </div>
      <p class="text-slate-400 text-sm mt-4 md:mt-0 fade-in">Arrastra para comparar</p>
    </div>

    <div class="ba-wrap rounded-[2rem] aspect-[16/10] md:aspect-[16/9] fade-in" id="ba">
      <img src="/img/before.jpg" alt="Antes" class="w-full h-full object-cover" />
      <div class="ba-over" id="ba-over" style="clip-path: inset(0 50% 0 0);">
        <img src="/img/after.jpg" alt="Después" class="w-full h-full object-cover" />
      </div>
      <div class="ba-line" id="ba-line" style="left:50%;">
        <div class="ba-knob">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2.5" stroke-linecap="round"><path d="M8 5l-5 7 5 7M16 5l5 7-5 7"/></svg>
        </div>
      </div>
      <span class="absolute top-5 left-5 bg-black/50 backdrop-blur text-white text-[11px] font-black tracking-widest uppercase px-4 py-1.5 rounded-full z-20">Antes</span>
      <span class="absolute top-5 right-5 bg-[var(--blue)] text-white text-[11px] font-black tracking-widest uppercase px-4 py-1.5 rounded-full z-20">Después</span>
    </div>
  </div>
</section>


<!-- ████ BOOKSY / RESERVAR ████ -->
<section id="reservar" class="py-32 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="bg-slate-900 rounded-[3rem] overflow-hidden shadow-2xl relative">
      <!-- Decorative skew -->
      <div class="absolute top-0 right-0 w-1/2 h-full bg-[var(--blue)]/10 skew-x-12 translate-x-1/4 pointer-events-none"></div>

      <div class="grid md:grid-cols-2 gap-0 relative z-10">
        <div class="p-10 md:p-20 flex flex-col justify-center fade-in">
          <div class="flex items-center gap-3 text-[var(--blue)] mb-6">
            <div class="w-10 h-px bg-[var(--blue)]"></div>
            <span class="text-xs font-black tracking-[0.3em] uppercase">Reserva Online</span>
          </div>

          <h2 class="text-4xl md:text-6xl font-black text-white mb-8 leading-tight tracking-tighter">
            Gestiona tu cita<br/>vía <span class="text-[var(--blue)]">Booksy.</span>
          </h2>

          <p class="text-slate-400 text-lg mb-10 leading-relaxed">
            Agenda tu visita en segundos: elige servicio y hora con confirmación al instante.
          </p>

          <div class="space-y-4 mb-12">
            {['Disponibilidad real 24/7', 'Recordatorios automáticos', 'Gestión desde el móvil', 'Sin esperas'].map((item) => (
              <div class="flex items-center gap-3 text-slate-300">
                <svg class="w-5 h-5 text-[var(--blue)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="font-medium">{item}</span>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="https://booksy.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-3 bg-[var(--blue)] text-white px-10 py-5 rounded-2xl font-black text-xl hover:bg-[var(--blue-dark)] transition shadow-xl shadow-[var(--blue)]/30">
              RESERVAR AHORA <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
            </a>
            <a href="https://wa.me/34XXXXXXXXX" target="_blank" class="inline-flex items-center justify-center gap-3 bg-[#25D366] text-white px-8 py-5 rounded-2xl font-bold text-lg hover:brightness-110 transition">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          </div>
        </div>

        <!-- Phone mockup -->
        <div class="hidden md:flex items-center justify-center bg-slate-950/30 p-12">
          <div class="relative w-64 h-[500px] bg-slate-900 rounded-[2.5rem] border-8 border-slate-800 shadow-2xl overflow-hidden p-6">
            <div class="w-10 h-1 bg-slate-800 mx-auto rounded-full mb-8"></div>
            <div class="space-y-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-[var(--blue)]/20"></div>
                <div class="w-24 h-3 skel"></div>
              </div>
              <div class="w-full h-32 skel rounded-2xl"></div>
              <div class="grid grid-cols-3 gap-2">
                {[...Array(9)].map((_, i) => (
                  <div class="h-8 skel rounded-md"></div>
                ))}
              </div>
              <div class="w-full h-12 bg-[var(--blue)]/20 rounded-xl mt-4"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ████ CONTACTO ████ -->
<section id="contacto" class="py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <div class="fade-in">
        <h2 class="text-5xl md:text-6xl font-black text-slate-900 mb-8 tracking-tighter">
          Visítanos en<br/><span class="text-[var(--blue)] underline decoration-slate-900">Puerto de Sagunto.</span>
        </h2>

        <div class="grid sm:grid-cols-2 gap-6 mt-12">
          {[
            { icon: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z', label: 'Ubicación', text: 'Calle ejemplo, 123<br/>46520 Puerto de Sagunto' },
            { icon: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z', label: 'Horario', text: 'Lun – Vie: 10:00 – 20:00<br/>Sáb: 10:00 – 14:00<br/><span class="text-slate-400">Dom: Cerrado</span>' },
            { icon: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z', label: 'Llámanos', text: '<span class="text-slate-600 font-bold text-lg">+34 XXX XXX XXX</span>' },
            { icon: 'M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z', label: 'WhatsApp', text: '<a href="https://wa.me/34XXXXXXXXX" class="text-[var(--blue)] font-bold text-lg hover:underline">Escríbenos</a>' },
          ].map(({ icon, label, text }) => (
            <div class="p-8 rounded-3xl bg-slate-50 border border-slate-100 fade-in">
              <div class="w-12 h-12 bg-[var(--blue)]/10 text-[var(--blue)] rounded-xl flex items-center justify-center mb-6">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={icon}/></svg>
              </div>
              <h4 class="font-black text-slate-900 mb-2 uppercase tracking-widest text-xs">{label}</h4>
              <div class="text-slate-600 font-medium text-sm" set:html={text} />
            </div>
          ))}
        </div>
      </div>

      <div class="w-full h-[500px] lg:h-full min-h-[450px] rounded-[3rem] overflow-hidden border-8 border-slate-50 shadow-2xl bg-slate-100 fade-in">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d12288!2d-0.214!3d39.6447!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd601a7e5c3fffff%3A0x4000000000000000!2sPuerto%20de%20Sagunto%2C%20Valencia!5e0!3m2!1ses!2ses!4v1"
          width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
          referrerpolicy="no-referrer-when-downgrade" title="Ubicación"
        ></iframe>
      </div>
    </div>
  </div>
</section>


<!-- ████ FOOTER ████ -->
<footer class="bg-slate-950 text-white pt-24 pb-12 px-6">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12 border-b border-white/5 pb-16 mb-12 text-center md:text-left">
    <div>
      <div class="flex items-center justify-center md:justify-start gap-2 mb-4">
        <svg class="w-8 h-8 text-[var(--blue)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M14.121 14.121A3 3 0 109.88 9.88m4.243 4.243L7.05 7.05m9.9 9.9L7.05 7.05m9.9 9.9L16.95 7.05l-9.9 9.9"/></svg>
        <span class="text-3xl font-black tracking-tighter">ÁNGEL HUERTA</span>
      </div>
      <p class="text-slate-500 max-w-sm">Barbería profesional en Puerto de Sagunto. Tu estilo, nuestra pasión.</p>
    </div>
    <div class="flex flex-col items-center md:items-end gap-6">
      <div class="flex gap-4">
        <a href="#" class="w-14 h-14 rounded-2xl bg-white/5 flex items-center justify-center text-slate-400 hover:text-[var(--blue)] hover:-translate-y-1 transition-all">
