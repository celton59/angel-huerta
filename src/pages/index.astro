<script>
  // ── Navbar scroll ──
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      navbar?.classList.add('nav-scrolled');
      navbar?.querySelectorAll('.nav-logo').forEach(el => el.classList.add('!text-[#1A1A1A]'));
      navbar?.querySelectorAll('.nav-link').forEach(el => { el.classList.remove('text-white/80'); el.classList.add('text-[#4A4A4A]'); });
      (navbar?.querySelector('button') as HTMLElement)?.classList.replace('text-white', 'text-[#1A1A1A]');
    } else {
      navbar?.classList.remove('nav-scrolled');
      navbar?.querySelectorAll('.nav-logo').forEach(el => el.classList.remove('!text-[#1A1A1A]'));
      navbar?.querySelectorAll('.nav-link').forEach(el => { el.classList.remove('text-[#4A4A4A]'); el.classList.add('text-white/80'); });
      (navbar?.querySelector('button') as HTMLElement)?.classList.replace('text-[#1A1A1A]', 'text-white');
    }
  }, { passive: true });

  // ── Mobile menu ──
  document.getElementById('mobile-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
  document.querySelectorAll('.mobile-link').forEach(l => {
    l.addEventListener('click', () => document.getElementById('mobile-menu')?.classList.add('hidden'));
  });

  // ── Scroll reveals ──
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(el => io.observe(el));

  // ── Counter animation ──
  const counterIO = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      let current = 0;
      const step = Math.max(1, Math.floor(target / 40));
      const timer = setInterval(() => {
        current += step;
        if (current >= target) { current = target; clearInterval(timer); }
        el.textContent = current + (target > 1 ? '+' : '');
      }, 30);
      counterIO.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.counter').forEach(el => counterIO.observe(el));

  // ── Before/After slider ──
  const slider = document.getElementById('ba-slider');
  const afterEl = document.getElementById('ba-after');
  const handle = document.getElementById('ba-handle');
  if (slider && afterEl && handle) {
    let dragging = false;
    const move = (x: number) => {
      const rect = slider.getBoundingClientRect();
      let pct = ((x - rect.left) / rect.width) * 100;
      pct = Math.max(2, Math.min(98, pct));
      afterEl.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
      handle.style.left = pct + '%';
    };
    slider.addEventListener('mousedown', (e) => { dragging = true; move(e.clientX); });
    window.addEventListener('mousemove', (e) => { if (dragging) move(e.clientX); });
    window.addEventListener('mouseup', () => { dragging = false; });
    slider.addEventListener('touchstart', (e) => { dragging = true; move(e.touches[0].clientX); }, { passive: true });
    window.addEventListener('touchmove', (e) => { if (dragging) move(e.touches[0].clientX); });
    window.addEventListener('touchend', () => { dragging = false; });
  }
</script>
