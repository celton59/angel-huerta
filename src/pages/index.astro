---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- ═══════════ NAVBAR ═══════════ -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="#" class="flex items-center gap-2">
        <svg class="w-6 h-6 text-[var(--color-blue)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M14.121 14.121A3 3 0 1 0 9.88 9.88M7.05 7.05l9.9 9.9M16.95 7.05l-9.9 9.9"/></svg>
        <span class="font-display text-xl font-bold text-white nav-logo tracking-wide">ÁNGEL HUERTA</span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#servicios" class="text-sm text-white/80 hover:text-white transition-colors nav-link">Servicios</a>
        <a href="#sobre-mi" class="text-sm text-white/80 hover:text-white transition-colors nav-link">Sobre mí</a>
        <a href="#galeria" class="text-sm text-white/80 hover:text-white transition-colors nav-link">Galería</a>
        <a href="#contacto" class="text-sm text-white/80 hover:text-white transition-colors nav-link">Contacto</a>
        <a href="#reservar" class="bg-[var(--color-blue)] text-white px-6 py-2.5 rounded-full font-semibold text-sm hover:bg-[var(--color-blue-dark)] transition-all shadow-lg shadow-[var(--color-blue)]/20 flex items-center gap-1.5">
          Reservar Cita <span class="text-xs">→</span>
        </a>
      </div>
      <button id="mobile-toggle" class="md:hidden text-white p-2" aria-label="Menú">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
    <div id="mobile-menu" class="md:hidden hidden bg-white/95 backdrop-blur-xl border-t border-[var(--color-border)]">
      <div class="px-6 py-6 flex flex-col gap-4">
        <a href="#servicios" class="text-[var(--color-text)] hover:text-[var(--color-blue)] transition-colors py-2 mobile-link">Servicios</a>
        <a href="#sobre-mi" class="text-[var(--color-text)] hover:text-[var(--color-blue)] transition-colors py-2 mobile-link">Sobre mí</a>
        <a href="#galeria" class="text-[var(--color-text)] hover:text-[var(--color-blue)] transition-colors py-2 mobile-link">Galería</a>
        <a href="#contacto" class="text-[var(--color-text)] hover:text-[var(--color-blue)] transition-colors py-2 mobile-link">Contacto</a>
        <a href="#reservar" class="bg-[var(--color-blue)] text-white px-6 py-3 rounded-full font-semibold text-sm text-center mt-2 mobile-link">Reservar Cita</a>
      </div>
    </div>
  </nav>


  <!-- ═══════════ HERO — foto de fondo ═══════════ -->
  <section class="relative min-h-screen flex items-center">
    <img src="/img/hero-bg.jpg" alt="Barbería Ángel Huerta" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="hero-overlay absolute inset-0"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 pt-28 pb-20 w-full">
      <div class="max-w-2xl">
        <div class="hero-fade hero-fade-d1 inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-5 py-2 mb-8">
          <svg class="w-4 h-4 text-[var(--color-blue)]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          <span class="text-sm text-white/90 font-medium">Puerto de Sagunto, Valencia</span>
        </div>

        <h1 class="hero-fade hero-fade-d2 font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl text-white font-bold leading-[1.05] mb-6">
          Tu barbero<br/>de confianza
        </h1>

        <p class="hero-fade hero-fade-d3 text-white/70 text-lg md:text-xl max-w-lg mb-10 leading-relaxed">
          Más de 40 años de experiencia haciendo que cada cliente salga sintiéndose su mejor versión.
        </p>

        <div class="hero-fade hero-fade-d4 flex flex-col sm:flex-row gap-4 items-start">
          <a href="#reservar" class="bg-[var(--color-blue)] text-white px-8 py-4 rounded-full font-semibold text-sm hover:bg-[var(--color-blue-dark)] transition-all shadow-lg shadow-[var(--color-blue)]/30 flex items-center gap-2">
            Reservar Cita <span>→</span>
          </a>
          <a href="#servicios" class="border border-white/30 text-white px-8 py-4 rounded-full font-semibold text-sm hover:bg-white/10 transition-all">
            Ver Servicios
          </a>
        </div>

        <!-- Rating -->
        <div class="hero-fade hero-fade-d4 mt-8 flex items-center gap-3">
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <span class="text-white/60 text-sm">+200 reseñas en Google</span>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════ BARRA DE CONFIANZA ═══════════ -->
  <section class="bg-white border-b border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto px-6 py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0 md:divide-x divide-[var(--color-border)]">
        {[
          { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', label: '40+ años', sub: 'de experiencia' },
          { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z', label: 'Miles', sub: 'de clientes' },
          { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', label: '5 ★', sub: 'en Google' },
          { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', label: 'Puerto de Sagunto', sub: 'Valencia' },
        ].map(({ icon, label, sub }) => (
          <div class="flex items-center gap-3 md:justify-center md:px-4">
            <svg class="w-5 h-5 text-[var(--color-blue)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={icon}/></svg>
            <div>
              <p class="text-sm font-bold text-[var(--color-black)]">{label}</p>
              <p class="text-xs text-[var(--color-text)]">{sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════ ANTES / DESPUÉS — slider ═══════════ -->
  <section class="py-20 md:py-28 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14 reveal">
        <div class="section-label">
          <span class="text-[var(--color-blue)] text-xs font-semibold uppercase tracking-widest">Resultados</span>
        </div>
        <h2 class="font-display text-3xl md:text-5xl text-[var(--color-black)] font-bold mb-4">El resultado habla por sí solo</h2>
        <p class="text-[var(--color-text)] text-lg">Arrastra para comparar el antes y después</p>
      </div>

      <div class="ba-slider reveal" id="ba-slider" style="aspect-ratio: 4/3;">
        <!-- Before (full width background) -->
        <img src="/img/before.jpg" alt="Antes" class="w-full h-full object-cover" />
        <!-- After (clipped) -->
        <div class="ba-after" id="ba-after" style="clip-path: inset(0 50% 0 0);">
          <img src="/img/after.jpg" alt="Después" class="w-full h-full object-cover" />
        </div>
        <!-- Handle -->
        <div class="ba-handle" id="ba-handle" style="left: 50%;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3E76B6" stroke-width="2.5" stroke-linecap="round"><path d="M8 5l-5 7 5 7M16 5l5 7-5 7"/></svg>
        </div>
        <!-- Labels -->
        <span class="absolute top-4 left-4 bg-black/60 backdrop-blur-sm text-white text-xs font-semibold px-3 py-1.5 rounded-full z-20">ANTES</span>
        <span class="absolute top-4 right-4 bg-[var(--color-blue)] text-white text-xs font-semibold px-3 py-1.5 rounded-full z-20">DESPUÉS</span>
      </div>

      <div class="text-center mt-14 reveal">
        <p class="text-[var(--color-black)] text-xl md:text-2xl font-display font-bold mb-6">¿Quieres estos resultados?</p>
        <a href="#reservar" class="inline-flex items-center gap-2 bg-[var(--color-blue)] text-white px-8 py-4 rounded-full font-semibold text-sm hover:bg-[var(--color-blue-dark)] transition-all shadow-lg shadow-[var(--color-blue)]/20">
          Reserva tu cita <span>→</span>
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════ SERVICIOS ═══════════ -->
  <section id="servicios" class="py-20 md:py-28 px-6 bg-[var(--color-light)]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <div class="section-label">
          <span class="text-[var(--color-blue)] text-xs font-semibold uppercase tracking-widest">Servicios</span>
        </div>
        <h2 class="font-display text-3xl md:text-5xl text-[var(--color-black)] font-bold mb-4">Nuestros servicios</h2>
        <p class="text-[var(--color-text)] text-lg">Todo lo que necesitas en un solo sitio</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { d: 'M14.121 14.121A3 3 0 109.88 9.88m4.243 4.243L7.05 7.05m9.9 9.9L7.05 7.05m9.9 9.9L16.95 7.05l-9.9 9.9', title: 'Corte Clásico', price: '15€', desc: 'Corte tradicional a tijera con acabado perfecto. La esencia de la barbería de toda la vida.' },
          { d: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'Degradado', price: '14€', desc: 'Degradados limpios y precisos. Del skin fade al mid fade, adaptado a tu estilo.' },
          { d: 'M3 6l3 1m0 0l-3 9a5 5 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5 5 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3', title: 'Afeitado Clásico', price: '10€', desc: 'Afeitado a navaja con toalla caliente. Una experiencia clásica de barbería.' },
          { d: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z', title: 'Arreglo de Barba', price: '8€', desc: 'Perfilado, recorte y cuidado de barba. Dale forma y estilo.' },
          { d: 'M14.121 14.121A3 3 0 109.88 9.88M12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z', title: 'Corte + Barba', price: '18€', desc: 'El servicio completo. Corte y barba en una sola sesión.' },
          { d: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', title: 'Tratamiento Capilar', price: 'Consultar', desc: 'Tratamientos personalizados para la salud de tu cabello.' },
        ].map(({ d, title, price, desc }) => (
          <div class="service-card bg-white rounded-2xl p-7 shadow-sm border border-[var(--color-border)] reveal">
            <div class="w-12 h-12 bg-[var(--color-blue)]/10 rounded-xl flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-[var(--color-blue)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={d}/></svg>
            </div>
            <div class="flex items-baseline justify-between mb-2">
              <h3 class="text-lg font-bold text-[var(--color-black)]">{title}</h3>
              <span class="bg-[var(--color-blue)]/10 text-[var(--color-blue)] text-sm font-bold px-3 py-1 rounded-lg">{price}</span>
            </div>
            <p class="text-[var(--color-text)] text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════ SOBRE ÁNGEL ═══════════ -->
  <section id="sobre-mi" class="py-20 md:py-28 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 reveal-left">
          <div class="relative">
            <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-xl">
              <img src="/img/barber-portrait.jpg" alt="Ángel Huerta, barbero profesional en Puerto de Sagunto" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="absolute -bottom-4 -right-4 bg-[var(--color-blue)] text-white px-5 py-3 rounded-xl shadow-lg">
              <p class="font-display text-2xl font-bold">40+</p>
              <p class="text-xs text-white/80">años de oficio</p>
            </div>
          </div>
        </div>

        <div class="md:col-span-7 reveal-right">
          <div class="section-label justify-start">
            <span class="text-[var(--color-blue)] text-xs font-semibold uppercase tracking-widest">Sobre mí</span>
          </div>
          <h2 class="font-display text-3xl md:text-5xl text-[var(--color-black)] font-bold mb-8">Ángel Huerta</h2>

          <p class="text-[var(--color-text)] leading-relaxed mb-5 text-lg">
            Llevo más de 40 años detrás de la silla de barbero. Empecé siendo un chaval en Puerto de Sagunto y aquí sigo, haciendo lo que más me gusta: que cada cliente salga sintiéndose mejor.
          </p>
          <p class="text-[var(--color-text)] leading-relaxed mb-8">
            Fuera de la barbería, el culturismo me enseñó disciplina y constancia. Y cuando necesito desconectar, me subo a la moto y me pierdo por carretera. Pero siempre vuelvo a lo mío: las tijeras y la navaja.
          </p>

          <blockquote class="border-l-4 border-[var(--color-blue)] pl-6 mb-10 relative">
            <svg class="absolute -top-3 -left-1 w-8 h-8 text-[var(--color-blue)]/20" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z"/></svg>
            <p class="text-[var(--color-black)] text-lg italic leading-relaxed font-display">
              "No es solo un corte de pelo. Es hacer que te mires al espejo y te gustes."
            </p>
          </blockquote>

          <div class="grid grid-cols-3 gap-6">
            <div>
              <p class="font-display text-3xl md:text-4xl text-[var(--color-blue)] font-bold counter" data-target="40">0</p>
              <p class="text-[var(--color-text)] text-sm mt-1">años de oficio</p>
            </div>
            <div>
              <p class="font-display text-3xl md:text-4xl text-[var(--color-blue)] font-bold">Miles</p>
              <p class="text-[var(--color-text)] text-sm mt-1">de clientes</p>
            </div>
            <div>
              <p class="font-display text-3xl md:text-4xl text-[var(--color-blue)] font-bold counter" data-target="1">0</p>
              <p class="text-[var(--color-text)] text-sm mt-1">pasión</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════ TESTIMONIOS ═══════════ -->
  <section class="py-20 md:py-28 px-6 bg-[var(--color-nardo)]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <div class="section-label">
          <span class="text-[var(--color-blue)] text-xs font-semibold uppercase tracking-widest">Opiniones</span>
        </div>
        <h2 class="font-display text-3xl md:text-5xl text-[var(--color-black)] font-bold mb-4">Lo que dicen nuestros clientes</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          { img: '/img/avatar-1.jpg', text: 'Llevo yendo a Ángel más de 15 años. No cambio de barbero ni loco. Es un crack con las tijeras.', name: 'Carlos M.', years: 'Cliente desde 2011' },
          { img: '/img/avatar-2.jpg', text: 'Mi padre ya iba con él. Ahora voy yo con mis hijos. Tres generaciones en la misma silla.', name: 'David R.', years: 'Cliente desde 2018' },
          { img: '/img/avatar-3.jpg', text: 'El mejor degradado de todo Puerto de Sagunto, sin discusión. Y encima buen tío.', name: 'Javier L.', years: 'Cliente desde 2020' },
        ].map(({ img, text, name, years }) => (
          <div class="testimonial-card bg-white rounded-2xl p-7 shadow-sm reveal">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-[var(--color-text)] italic leading-relaxed mb-6">"{text}"</p>
            <div class="flex items-center gap-3">
              <img src={img} alt={name} class="w-10 h-10 rounded-full object-cover" loading="lazy" />
              <div>
                <p class="text-sm font-bold text-[var(--color-black)]">{name}</p>
                <p class="text-xs text-[var(--color-text)]">{years}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════ GALERÍA ═══════════ -->
  <section id="galeria" class="py-20 md:py-28 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <div class="section-label">
          <span class="text-[var(--color-blue)] text-xs font-semibold uppercase tracking-widest">Portfolio</span>
        </div>
        <h2 class="font-display text-3xl md:text-5xl text-[var(--color-black)] font-bold mb-4">Nuestro trabajo</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 reveal">
        {[
          { src: '/img/gallery-1.jpg', span: 'md:row-span-2', aspect: 'aspect-[3/4]' },
          { src: '/img/gallery-2.jpg', span: '', aspect: 'aspect-square' },
          { src: '/img/gallery-3.jpg', span: '', aspect: 'aspect-square' },
          { src: '/img/gallery-4.jpg', span: '', aspect: 'aspect-square' },
          { src: '/img/gallery-5.jpg', span: '', aspect: 'aspect-square' },
          { src: '/img/gallery-6.jpg', span: '', aspect: 'aspect-square' },
        ].map(({ src, span, aspect }) => (
          <div class={`gallery-item ${span} relative`}>
            <img src={src} alt="Trabajo de Ángel Huerta" class={`w-full h-full object-cover ${aspect}`} loading="lazy" />
            <div class="gallery-overlay absolute inset-0 bg-black/30 flex items-center justify-center rounded-xl">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6"/></svg>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════ RESERVAS / BOOKSY ═══════════ -->
  <section id="reservar" class="py-20 md:py-28 px-6 bg-[var(--color-light)]">
    <div class="max-w-4xl mx-auto text-center">
      <div class="reveal">
        <div class="section-label">
          <span class="text-[var(--color-blue)] text-xs font-semibold uppercase tracking-widest">Citas</span>
        </div>
        <h2 class="font-display text-3xl md:text-5xl text-[var(--color-black)] font-bold mb-4">Reserva tu cita</h2>
