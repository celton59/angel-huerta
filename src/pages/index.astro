<script>
  // Navbar
  const nav = document.getElementById('nav')!;
  addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 60), { passive: true });

  // Mobile
  document.getElementById('burger')!.onclick = () => document.getElementById('mob-menu')!.classList.toggle('hidden');
  document.querySelectorAll('.mob-link').forEach(l => l.addEventListener('click', () => document.getElementById('mob-menu')!.classList.add('hidden')));

  // Fade-up
  const io = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }}), { threshold: 0.1 });
  document.querySelectorAll('.fade-up, .img-zoom').forEach(el => io.observe(el));

  // Before/After
  const ba = document.getElementById('ba');
  const over = document.getElementById('ba-over');
  const line = document.getElementById('ba-line');
  if (ba && over && line) {
    let d = false;
    const m = (x: number) => { const r = ba.getBoundingClientRect(); let p = Math.max(2, Math.min(98, ((x-r.left)/r.width)*100)); over.style.clipPath = `inset(0 ${100-p}% 0 0)`; line.style.left = p+'%'; };
    ba.onmousedown = e => { d=true; m(e.clientX); };
    onmousemove = e => { if(d) m(e.clientX); };
    onmouseup = () => d=false;
    ba.addEventListener('touchstart', e => { d=true; m(e.touches[0].clientX); }, { passive: true });
    addEventListener('touchmove', e => { if(d) m(e.touches[0].clientX); });
    addEventListener('touchend', () => d=false);
  }
</script>
