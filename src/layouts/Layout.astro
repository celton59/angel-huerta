---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ángel Huerta | Barbería en Puerto de Sagunto — Más de 40 años de experiencia',
  description = 'Barbería profesional en Puerto de Sagunto, Valencia. Cortes, degradados, afeitado clásico y barba. Más de 40 años de experiencia. Reserva tu cita.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="barbería, barbería puerto de sagunto, peluquero sagunto, barbero puerto sagunto, corte de pelo sagunto, degradado, afeitado clásico, barba, peluquería hombre valencia" />
  <title>{title}</title>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href="https://angelhuerta.es/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://angelhuerta.es/" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://angelhuerta.es/img/hero-bg.jpg" />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:site_name" content="Ángel Huerta Barbería" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://angelhuerta.es/img/hero-bg.jpg" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,700&display=swap" rel="stylesheet" />

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BarberShop",
    "name": "Ángel Huerta — Barbería",
    "description": description,
    "url": "https://angelhuerta.es",
    "telephone": "+34XXXXXXXXX",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calle ejemplo, 123",
      "addressLocality": "Puerto de Sagunto",
      "addressRegion": "Valencia",
      "postalCode": "46520",
      "addressCountry": "ES"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 39.6447,
      "longitude": -0.2140
    },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "10:00", "closes": "20:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "10:00", "closes": "14:00" }
    ],
    "priceRange": "€",
    "image": "https://angelhuerta.es/img/hero-bg.jpg",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "200"
    }
  })} />

  <style>
    @import "../styles/global.css";
  </style>
</head>
<body class="min-h-screen bg-white">
  <slot />
</body>
</html>
